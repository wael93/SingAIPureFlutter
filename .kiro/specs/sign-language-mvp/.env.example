# ملف مثال للإعدادات - لا ترفع هذا الملف إلى GitHub
# استخدم هذا كنموذج فقط

# إعدادات التطوير (بدون بيانات حقيقية)
# هذه القيم ستُستبدل بقيم حقيقية عند التكوين

# مفتاح API (مثال - لا تستخدم هذا المفتاح)
# API_KEY=your_api_key_here

# رابط قاعدة البيانات (مثال)
# DATABASE_URL=your_database_url_here

# إعدادات أخرى
# DEBUG_MODE=true
# LOG_LEVEL=debug

# ملاحظة: هذا الملف مهمل في .gitignore
# لا ترفع ملف .env الحقيقي إلى GitHub
